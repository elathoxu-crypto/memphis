#!/usr/bin/env bash
#
# Memphis Pre-Commit Hook
# Validates chain integrity before allowing commits
#
# @version 3.0.1
# @date 2026-03-03

set -e

echo "🛡️ Memphis Pre-Commit Validation..."
echo ""

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track validation status
VALIDATION_PASSED=true

# 1. Check if Memphis is initialized
echo "📦 Checking Memphis initialization..."
if [ ! -d "$HOME/.memphis/chains" ]; then
    echo -e "${YELLOW}⚠️  Warning: Memphis chains directory not found${NC}"
    echo "   Skipping chain validation (Memphis not initialized)"
    exit 0
fi

# 2. Validate chain integrity
echo "🔗 Validating chain integrity..."
MEMPHIS_CLI="node $(git rev-parse --show-toplevel)/dist/cli/index.js"

if [ -f "$(git rev-parse --show-toplevel)/dist/cli/index.js" ]; then
    # Run chain verification
    VERIFICATION_OUTPUT=$($MEMPHIS_CLI verify 2>&1)
    
    if echo "$VERIFICATION_OUTPUT" | grep -q "✓"; then
        echo -e "${GREEN}✓ Chain integrity verified${NC}"
    else
        echo -e "${RED}✗ Chain integrity check failed${NC}"
        echo "$VERIFICATION_OUTPUT"
        VALIDATION_PASSED=false
    fi
else
    echo -e "${YELLOW}⚠️  Memphis CLI not built, skipping chain verification${NC}"
    echo "   Run: npm run build"
fi

# 3. Check for broken blocks
echo ""
echo "🔍 Checking for broken blocks..."
BROKEN_BLOCKS=$(find "$HOME/.memphis/chains" -name "*.json" -exec grep -l '"broken":true' {} \; 2>/dev/null | wc -l)

if [ "$BROKEN_BLOCKS" -gt 0 ]; then
    echo -e "${RED}✗ Found $BROKEN_BLOCKS broken blocks${NC}"
    echo "   Run: memphis repair --auto"
    VALIDATION_PASSED=false
else
    echo -e "${GREEN}✓ No broken blocks found${NC}"
fi

# 4. Validate block hashes (sample check)
echo ""
echo "🔐 Validating block hashes..."
SAMPLE_CHAINS=("journal" "decision" "ask")

for chain in "${SAMPLE_CHAINS[@]}"; do
    CHAIN_FILE="$HOME/.memphis/chains/$chain.json"
    if [ -f "$CHAIN_FILE" ]; then
        # Check last 5 blocks for valid hashes
        RECENT_BLOCKS=$(tail -n 5 "$CHAIN_FILE" 2>/dev/null | grep -c '"hash"' || true)
        if [ "$RECENT_BLOCKS" -ge 3 ]; then
            echo -e "${GREEN}✓ $chain chain: hash validation passed${NC}"
        else
            echo -e "${YELLOW}⚠️  $chain chain: insufficient blocks for validation${NC}"
        fi
    fi
done

# 5. Check for pending repairs
echo ""
echo "🔧 Checking for pending repairs..."
if [ -f "$HOME/.memphis/.repair-pending" ]; then
    echo -e "${RED}✗ Pending repairs detected${NC}"
    echo "   Complete repairs before committing"
    echo "   Run: memphis repair --complete"
    VALIDATION_PASSED=false
else
    echo -e "${GREEN}✓ No pending repairs${NC}"
fi

# 6. Create automatic backup before commit
echo ""
echo "💾 Creating pre-commit backup..."
BACKUP_DIR="$HOME/.memphis/backups/pre-commit"
BACKUP_FILE="backup-$(date +%Y%m%d-%H%M%S).tar.gz"

mkdir -p "$BACKUP_DIR"
tar -czf "$BACKUP_DIR/$BACKUP_FILE" -C "$HOME/.memphis" chains/ 2>/dev/null || true

if [ -f "$BACKUP_DIR/$BACKUP_FILE" ]; then
    BACKUP_SIZE=$(du -h "$BACKUP_DIR/$BACKUP_FILE" | cut -f1)
    echo -e "${GREEN}✓ Backup created: $BACKUP_FILE ($BACKUP_SIZE)${NC}"
    
    # Clean old backups (keep last 10)
    ls -t "$BACKUP_DIR"/backup-*.tar.gz 2>/dev/null | tail -n +11 | xargs rm -f 2>/dev/null || true
else
    echo -e "${YELLOW}⚠️  Backup creation failed (non-critical)${NC}"
fi

# Final decision
echo ""
echo "═══════════════════════════════════════════════════════"

if [ "$VALIDATION_PASSED" = true ]; then
    echo -e "${GREEN}✅ All validations passed!${NC}"
    echo "   Commit allowed"
    echo "═══════════════════════════════════════════════════════"
    exit 0
else
    echo -e "${RED}❌ Validation failed!${NC}"
    echo "   Commit blocked"
    echo ""
    echo "Fix issues before committing:"
    echo "  1. Run: memphis verify"
    echo "  2. Run: memphis repair --auto"
    echo "  3. Run: memphis repair --complete"
    echo ""
    echo "To bypass (not recommended): git commit --no-verify"
    echo "═══════════════════════════════════════════════════════"
    exit 1
fi
